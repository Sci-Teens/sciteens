{
  "name": "sciteens",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "dev": "next dev",
    "build": "next build && next-sitemap",
    "start": "next start -p ${PORT:=3000}",
    "deploy": "",
    "lint": "next lint",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "pnpm test:unit && pnpm test:rules",
    "test:unit": "vitest run context lib components tests/pages",
    "test:watch": "vitest context lib components tests/pages",
    "test:rules": "firebase emulators:exec --project demo-sciteens-test --only firestore \"vitest run tests/rules\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@prismicio/client": "^5.2.0",
    "@react-spring/web": "^9.7.5",
    "@squoosh/lib": "^0.5.3",
    "@tailwindcss/typography": "^0.5.15",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.5",
    "algoliasearch": "^4.27.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression-webpack-plugin": "^10.0.0",
    "firebase": "^12.16.0",
    "image-minimizer-webpack-plugin": "^3.8.3",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^1.23.0",
    "moment": "^2.30.1",
    "next": "^14.2.15",
    "next-i18next": "^9.2.0",
    "next-slicezone": "^0.2.6",
    "nprogress": "^0.2.0",
    "prismic-dom": "^2.2.7",
    "prismic-reactjs": "^1.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^11.7.1",
    "react-hook-form": "^7.81.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.133.1",
    "tw-animate-css": "^1.4.0",
    "validator": "^13.15.35",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^4.2.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^15.23.0",
    "jsdom": "^29.1.1",
    "next-sitemap": "^1.9.12",
    "postcss": "^8.5.16",
    "prettier": "^2.8.8",
    "prettier-plugin-tailwindcss": "^0.1.13",
    "tailwindcss": "^4.3.2",
    "vitest": "^4.1.10"
  },
  "description": "This is the work-in-progress version of the open-source SciTeens platform. This application is built in Next JS (A Server-Side Rendered React JS framework.) If you encounter issues with the website, please fork our site and commit fixes or detail the issues in the issues tab on GitHub. If you just want to explore the code, then enjoy!",
  "main": ".eslintrc.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sci-Teens/sciteens.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Sci-Teens/sciteens/issues"
  },
  "homepage": "https://github.com/Sci-Teens/sciteens#readme"
}
